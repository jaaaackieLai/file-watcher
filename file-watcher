#!/usr/bin/env bash
set -euo pipefail

# file-watcher: Live file tree viewer for tmux panes
# Pure bash, zero external dependencies

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]:-$0}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"

source "${LIB_DIR}/constants.sh"
source "${LIB_DIR}/utils.sh"
source "${LIB_DIR}/tree.sh"
source "${LIB_DIR}/render.sh"
source "${LIB_DIR}/input.sh"

# ---- CLI ----

usage() {
    echo "file-watcher v${FW_VERSION} - Live file tree viewer"
    echo ""
    echo "Usage: file-watcher [OPTIONS] [DIRECTORY]"
    echo ""
    echo "Options:"
    echo "  -d, --depth N     Tree depth (default: ${DEFAULT_TREE_DEPTH}, max: ${MAX_TREE_DEPTH})"
    echo "  -a, --all         Show hidden files"
    echo "  -h, --help        Show this help"
    echo "  -v, --version     Show version"
    echo ""
    echo "Keys:"
    echo "  j/Down    Move down"
    echo "  k/Up      Move up"
    echo "  Enter     Enter directory"
    echo "  Backspace Go to parent"
    echo "  +/-       Increase/decrease depth"
    echo "  .         Toggle hidden files"
    echo "  g/G       Go to top/bottom"
    echo "  r         Refresh"
    echo "  q/ESC     Quit"
    echo ""
    echo "Management:"
    echo "  --uninstall   Remove file-watcher from system"
    echo "  --update      Update file-watcher from GitHub"
}

do_update() {
    command -v curl >/dev/null 2>&1 || die "curl is required for update"
    command -v jq >/dev/null 2>&1 || die "jq is required for update"

    echo "Checking for updates..."
    local remote_version
    remote_version=$(curl -fsSL "${FW_GITHUB_RAW_BASE}/lib/constants.sh" 2>/dev/null \
        | grep -oP 'FW_VERSION="\K[^"]+' || echo "")

    if [[ -z "$remote_version" ]]; then
        die "Cannot reach GitHub. Is ${FW_GITHUB_REPO} published?"
    fi

    if [[ "$remote_version" == "$FW_VERSION" ]]; then
        echo "Already up to date (v${FW_VERSION})."
        return 0
    fi

    echo "Updating v${FW_VERSION} -> v${remote_version}..."

    local data_dir="${HOME}/.local/share/file-watcher"
    local lib_files=(constants.sh utils.sh tree.sh render.sh input.sh)

    # Download main script
    curl -fsSL "${FW_GITHUB_RAW_BASE}/file-watcher" -o "${data_dir}/file-watcher.tmp" \
        || die "Failed to download file-watcher"
    chmod +x "${data_dir}/file-watcher.tmp"
    mv "${data_dir}/file-watcher.tmp" "${data_dir}/file-watcher"

    # Download lib files
    mkdir -p "${data_dir}/lib"
    local f
    for f in "${lib_files[@]}"; do
        curl -fsSL "${FW_GITHUB_RAW_BASE}/lib/${f}" -o "${data_dir}/lib/${f}.tmp" \
            || die "Failed to download lib/${f}"
        mv "${data_dir}/lib/${f}.tmp" "${data_dir}/lib/${f}"
    done

    echo "Updated to v${remote_version}!"
}

do_uninstall() {
    echo "Uninstalling file-watcher..."
    local data_dir="${HOME}/.local/share/file-watcher"
    local bin_link=""
    bin_link="$(command -v file-watcher 2>/dev/null || true)"

    if [[ -n "$bin_link" && -L "$bin_link" ]]; then
        rm -f "$bin_link" 2>/dev/null || sudo rm -f "$bin_link"
        echo "  Removed symlink: ${bin_link}"
    fi
    if [[ -d "$data_dir" ]]; then
        rm -rf "$data_dir" 2>/dev/null || sudo rm -rf "$data_dir"
        echo "  Removed data:    ${data_dir}/"
    fi
    echo "Uninstalled successfully."
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--depth)
                TREE_DEPTH="${2:-$DEFAULT_TREE_DEPTH}"
                shift 2
                ;;
            -a|--all)
                SHOW_HIDDEN=1
                shift
                ;;
            --update)
                do_update
                exit $?
                ;;
            --uninstall)
                do_uninstall
                exit 0
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                echo "file-watcher v${FW_VERSION}"
                exit 0
                ;;
            -*)
                echo "Unknown option: $1" >&2
                usage >&2
                exit 1
                ;;
            *)
                WATCH_DIR="$1"
                shift
                ;;
        esac
    done
}

# ---- Cleanup and main ----

SAVED_TTY=""

cleanup() {
    cursor_show
    clear_screen
    cursor_to 1 1
    if [[ -n "$SAVED_TTY" ]]; then
        stty "$SAVED_TTY" 2>/dev/null || true
    fi
}

main() {
    WATCH_DIR="${PWD}"
    parse_args "$@"

    # Resolve to absolute path
    WATCH_DIR="$(cd "$WATCH_DIR" 2>/dev/null && pwd)" || die "Cannot access directory: $WATCH_DIR"

    # Save terminal state and setup raw mode
    SAVED_TTY=$(stty -g 2>/dev/null || true)
    trap cleanup EXIT INT TERM
    trap 'DIRTY=1' WINCH
    stty -echo -icanon min 1 time 0 2>/dev/null || true

    cursor_hide
    clear_screen

    scan_directory
    render

    while $RUNNING; do
        handle_input
        if (( DIRTY )); then
            render
            DIRTY=0
        fi
    done
}

main "$@"
